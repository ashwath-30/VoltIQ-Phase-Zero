# Copy this file, rename the copy to ".env.local", and fill in the two
# values below from your Supabase project (Settings -> API).
#
# .env.local is already in .gitignore, so it will NOT be pushed to GitHub —
# that's intentional and correct. These are semi-public keys, safe for a
# browser to see, but there's no reason to publish them either.

NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-only — do NOT add NEXT_PUBLIC_ to this one. If you did, it would
# be shipped to the browser and anyone could see and use your key.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server-only. Found in Supabase under Settings -> API Keys, labeled
# "service_role" (NOT "anon"). This key bypasses all security rules, so
# treat it like a master password — only used by the scheduled background
# job in app/api/cron/check-stale-bills, never anywhere else.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Any random string you make up yourself (e.g. a long password). Protects
# the scheduled background job from being triggered by anyone who finds
# its URL. Vercel automatically sends this as a Bearer token when it runs
# your cron job for you, once deployed.
CRON_SECRET=make-up-a-long-random-string-here
